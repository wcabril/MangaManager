<Window x:Class="MangaManager.ReaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manga Reader"
        Background="#0A0A0A"
        WindowStyle="None"
        WindowState="Maximized"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Background="#111111">
            <Grid Margin="8,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>

                <!-- Volume selector -->
                <ComboBox x:Name="VolumeCombo" Grid.Column="0" Width="140"
                          VerticalAlignment="Center" FontSize="11"
                          SelectionChanged="VolumeCombo_Changed">
                    <ComboBox.Resources>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="#1E1E1E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </ComboBox.Resources>
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#2A2A2A"/>
                            <Setter Property="Foreground" Value="#CCCCCC"/>
                            <Setter Property="BorderBrush" Value="#444"/>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                <!-- Chapter selector -->
                <ComboBox x:Name="ChapterCombo" Grid.Column="1" Width="130"
                          VerticalAlignment="Center" FontSize="11" Margin="6,0,0,0"
                          SelectionChanged="ChapterCombo_Changed">
                    <ComboBox.Resources>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="#1E1E1E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </ComboBox.Resources>
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#2A2A2A"/>
                            <Setter Property="Foreground" Value="#CCCCCC"/>
                            <Setter Property="BorderBrush" Value="#444"/>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                <!-- Manga title -->
                <TextBlock x:Name="TitleText" Grid.Column="2"
                           Foreground="#555" FontSize="12"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis" Margin="12,0"/>

                <!-- Page counter -->
                <TextBlock x:Name="PageCounter" Grid.Column="3"
                           Foreground="#CCCCCC" FontSize="13" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>

                <!-- Close button -->
                <Button Grid.Column="4" Content="✕" Height="44"
                        Background="Transparent" Foreground="#888" BorderThickness="0"
                        FontSize="16" Click="Close_Click" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#CC3333"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- PAGE VIEWER -->
        <Grid Grid.Row="1" x:Name="ViewerGrid" Background="#0D0D0D">
            <!-- Current page image -->
            <Image x:Name="PageImage" Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <!-- Empty state message -->
            <StackPanel x:Name="EmptyPanel" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="📚" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock x:Name="EmptyText" Foreground="#555" FontSize="14" Margin="0,12,0,0"
                           HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>

            <!-- Navigation zones (invisible click areas) -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Left zone → previous page -->
                <Border Grid.Column="0" Background="Transparent" Cursor="Arrow"
                        MouseLeftButtonUp="PrevZone_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#08FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <!-- Right zone → next page -->
                <Border Grid.Column="1" Background="Transparent" Cursor="Arrow"
                        MouseLeftButtonUp="NextZone_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#08FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </Grid>
        </Grid>

        <!-- BOTTOM STATUS BAR -->
        <Border Grid.Row="2" Background="#111111">
            <Grid>
                <!-- Chapter progress within session -->
                <ProgressBar x:Name="ChapterProgress" Minimum="0" Maximum="100"
                             Background="Transparent" BorderThickness="0" Height="28">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Foreground" Value="#1d3d06"/>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
                <TextBlock x:Name="StatusText"
                           Foreground="#666" FontSize="10"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Keyboard hints on the right -->
                <TextBlock Foreground="#333" FontSize="9"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Text="← / → navigate   Esc close   Home/End first/last"/>
            </Grid>
        </Border>
    </Grid>
</Window>
