<Window x:Class="MangaManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manga Manager" Height="680" Width="1300"
        Background="#1E1E1E">

    <Window.Resources>

        <!-- Estilo dos botões com efeito de clique -->
        <Style TargetType="Button">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                    <Setter Property="Cursor" Value="No"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Card de mangá -->
        <Style x:Key="MangaCardStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="CardBorder" Background="#2D2D2D" CornerRadius="6"
                                BorderBrush="#444" BorderThickness="1" Padding="0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#888"/>
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- PASTA BASE -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Folder:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="BasePathBox" Width="900" IsReadOnly="True" VerticalAlignment="Center"
                     Background="#2D2D2D" Foreground="White" BorderBrush="#555"/>
            <Button Content="Select Folder" Click="SelectFolder_Click" Margin="8,0,0,0" Padding="10,4"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- GRID DE CARDS -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Manga List" Foreground="White" FontSize="16" Margin="0,0,0,5"/>
                <Button DockPanel.Dock="Bottom" Content="Refresh List" Click="Refresh_Click" Margin="0,8,0,0" Padding="0,5"/>
                <ScrollViewer x:Name="MangaScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ListBox x:Name="MangaList" Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource MangaCardStyle}"
                             SelectionChanged="MangaList_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             PreviewMouseWheel="MangaList_PreviewMouseWheel">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" Width="740"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="170" Margin="0">
                                    <!-- CAPA -->
                                    <Border Height="180" Background="#1a1a1a" CornerRadius="5,5,0,0">
                                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                    </Border>
                                    <!-- NOME -->
                                    <Border Background="{Binding StatusColor}" Padding="4,4,4,2">
                                        <TextBlock Text="{Binding Name}" Foreground="{Binding StatusForeground}"
                                                   FontWeight="{Binding StatusWeight}" FontSize="11"
                                                   TextWrapping="Wrap" TextAlignment="Center" MaxHeight="36"/>
                                    </Border>
                                    <!-- CHECKS -->
                                    <Border Background="#222" Padding="4,2,4,4" CornerRadius="0,0,5,5">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Chk1}" Foreground="#F448FA" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding Chk2}" Foreground="#0B47B1" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding Chk3}" Foreground="#F57927" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding Chk4}" Foreground="#F4F300" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding Chk5}" Foreground="#B1ED00" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding Chk6}" Foreground="#A855F7" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding Chk7}" Foreground="#E85D04" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding ChkKindle}" Foreground="White" FontSize="12" Margin="4,0,2,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </DockPanel>

            <!-- AÇÕES -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0">

                <!-- Author field -->
                <Grid Height="32" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#3A3A3A" BorderBrush="#555" BorderThickness="1,1,0,1" Width="80">
                        <TextBlock Text="Author" Foreground="#AAAAAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>
                    </Border>
                    <TextBox x:Name="AuthorBox" Grid.Column="1"
                             Background="#2D2D2D" Foreground="White" BorderBrush="#555"
                             VerticalContentAlignment="Center" Padding="6,0"/>
                </Grid>

                <Button x:Name="BtnFetchAuthor" Click="FetchAuthor_Click" Height="32" Margin="0,4,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#F448FA"/>
                                <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="🔍  Fetch Author and Volumes" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnOrganize" Click="OrganizeMangaDex_Click" Height="32" Margin="0,4,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#0B47B1"/>
                                <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="📂  Organize Chapters in Volumes" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnExtract" Click="Extract_Click" Height="32" Margin="0,4,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#F57927"/>
                                <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="📦  Extract" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- RESIZE: dropdown + botão -->
                <Grid Height="32" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Fill="#A855F7"/>
                    <ComboBox x:Name="DeviceCombo" Grid.Column="1"
                              Background="#DDDDDD" BorderThickness="0"
                              VerticalContentAlignment="Center" Padding="6,0"/>
                    <Button x:Name="BtnResize" Grid.Column="2" Click="Resize_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#DDDDDD" BorderBrush="#AAAAAA" BorderThickness="1,0,0,0">
                                    <TextBlock Text="🖼  Resize Images" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- GENERATE COMICINFO -->
                <Button x:Name="BtnComicInfo" Click="ComicInfo_Click" Height="32" Margin="0,4,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#F4F300"/>
                                <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="📋  Generate ComicInfo" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- CLEANUP -->
                <Button x:Name="BtnCleanup" Click="Cleanup_Click" Height="32" Margin="0,4,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#B1ED00"/>
                                <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="🧹  Cleanup Files" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- CONVERT TO MOBI -->
                <Button x:Name="BtnConvert" Click="Convert_Click" Height="32" Margin="0,4,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#E85D04"/>
                                <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="📗  Convert to MOBI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- VOLUME SELECTOR -->
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="Select which volumes you want to send to Kindle"
                               Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="ChkSendAll" Content="All" IsChecked="True"
                                  Foreground="White" VerticalAlignment="Center"
                                  Checked="ChkSendAll_Checked" Unchecked="ChkSendAll_Unchecked"
                                  Margin="0,0,12,0"/>
                        <CheckBox x:Name="ChkSendRange" Content="Range"
                                  Foreground="White" VerticalAlignment="Center"
                                  Checked="ChkSendRange_Checked" Unchecked="ChkSendRange_Unchecked"
                                  Margin="0,0,8,0"/>
                        <TextBox x:Name="VolumeRangeBox"
                                 Width="120" IsEnabled="False"
                                 Background="#2D2D2D" Foreground="White" BorderBrush="#555"
                                 VerticalContentAlignment="Center" Padding="6,2"
                                 Text="" Tag="1,2,3 or 1-6"/>
                    </StackPanel>
                </StackPanel>

                <!-- SEND TO KINDLE -->
                <Grid Height="32" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnSendToKindle" Grid.Column="0" Click="SendToKindle_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="#00A8E1"/>
                                    <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                        <TextBlock Text="📱  Send to Kindle" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BtnRemoveFromKindle" Grid.Column="1" Click="RemoveFromKindle_Click" Margin="4,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#DDDDDD" BorderBrush="#AAAAAA" BorderThickness="1,0,0,0">
                                    <TextBlock Text="🗑 Remove" Foreground="#CC3333" FontSize="11"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- PROGRESSO -->
                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="ProgressBar" Grid.Column="0" Height="18" Minimum="0" Maximum="100"/>
                    <Button x:Name="BtnCancel" Grid.Column="1" Click="Cancel_Click"
                            Margin="6,0,0,0" Height="18" IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#CC3333" CornerRadius="3">
                                    <TextBlock Text="⏹ Cancel" Foreground="White" FontSize="10"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Background" Value="#555555"/>
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#AA2222"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <TextBlock x:Name="ProgressText" Foreground="#AAAAAA" FontSize="12" Margin="0,2,0,0"/>

                <!-- LOG -->
                <TextBox x:Name="LogBox" Height="220" Margin="0,10,0,0"
                         IsReadOnly="True" TextWrapping="Wrap"
                         Background="#2D2D2D" Foreground="#CCCCCC" BorderBrush="#555"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
