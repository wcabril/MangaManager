<Window x:Class="MangaManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manga Manager" Height="580" Width="1100"
        Background="#1E1E1E">

    <Window.Resources>
        <Style TargetType="Button">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                    <Setter Property="Cursor" Value="No"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- PASTA BASE -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Folder:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="BasePathBox" Width="620" IsReadOnly="True" VerticalAlignment="Center"
                     Background="#2D2D2D" Foreground="White" BorderBrush="#555"/>
            <Button Content="Select Folder" Click="SelectFolder_Click"
                    Margin="8,0,0,0" Padding="10,4"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- LISTA -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Manga List" Foreground="White" FontSize="16" Margin="0,0,0,5"/>
                <ListBox x:Name="MangaList" Height="420" Background="#2D2D2D" BorderBrush="#555"
                         SelectionChanged="MangaList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Background="{Binding StatusColor}">
                                <TextBlock Text="{Binding Name}" Foreground="{Binding StatusForeground}"
                                           FontWeight="{Binding StatusWeight}" VerticalAlignment="Center" Margin="4,2,6,2"/>
                                <TextBlock Text="{Binding Chk1}" Foreground="#F448FA" FontWeight="Bold" VerticalAlignment="Center" Margin="2,0"/>
                                <TextBlock Text="{Binding Chk2}" Foreground="#0B47B1" FontWeight="Bold" VerticalAlignment="Center" Margin="2,0"/>
                                <TextBlock Text="{Binding Chk3}" Foreground="#F57927" FontWeight="Bold" VerticalAlignment="Center" Margin="2,0"/>
                                <TextBlock Text="{Binding Chk4}" Foreground="#F4F300" FontWeight="Bold" VerticalAlignment="Center" Margin="2,0"/>
                                <TextBlock Text="{Binding Chk5}" Foreground="#B1ED00" FontWeight="Bold" VerticalAlignment="Center" Margin="2,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Content="Refresh List" Click="Refresh_Click" Margin="0,8,0,0" Padding="0,5"/>
            </StackPanel>

            <!-- AÇÕES -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0">

                <!-- Author field com mesmo height dos botões -->
                <Grid Height="32" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#3A3A3A" BorderBrush="#555" BorderThickness="1,1,0,1"
                            Width="80" CornerRadius="0">
                        <TextBlock Text="Author" Foreground="#AAAAAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>
                    </Border>
                    <TextBox x:Name="AuthorBox" Grid.Column="1"
                             Background="#2D2D2D" Foreground="White" BorderBrush="#555"
                             VerticalContentAlignment="Center" Padding="6,0"/>
                </Grid>

                <Button x:Name="BtnFetchAuthor" Click="FetchAuthor_Click" Height="32" Margin="0,4,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#F448FA"/>
                                <Border Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="🔍  Fetch Author and Volumes (AniList)" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="BtnOrganize" Click="OrganizeMangaDex_Click" Height="32" Margin="0,4,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#0B47B1"/>
                                <Border Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="📂  Organize Chapters in Volumes" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="BtnExtract" Click="Extract_Click" Height="32" Margin="0,4,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#F57927"/>
                                <Border Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="📦  Extract CBZ" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="BtnComicInfo" Click="ComicInfo_Click" Height="32" Margin="0,4,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#F4F300"/>
                                <Border Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="📋  Generate ComicInfo" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="BtnCleanup" Click="Cleanup_Click" Height="32" Margin="0,4,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#B1ED00"/>
                                <Border Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="🧹  Cleanup CBZ Files" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- PROGRESSO -->
                <ProgressBar x:Name="ProgressBar" Height="18" Margin="0,14,0,4" Minimum="0" Maximum="100"/>
                <TextBlock x:Name="ProgressText" Foreground="#AAAAAA" FontSize="12"/>

                <!-- LOG -->
                <TextBox x:Name="LogBox" Height="155" Margin="0,10,0,0"
                         IsReadOnly="True" TextWrapping="Wrap"
                         Background="#2D2D2D" Foreground="#CCCCCC" BorderBrush="#555"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
