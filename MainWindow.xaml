<Window x:Class="MangaManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manga Manager" Height="680" Width="1300"
        Background="#1E1E1E">

    <Window.Resources>

        <!-- Estilo dos botões com efeito de clique -->
        <Style TargetType="Button">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                    <Setter Property="Cursor" Value="No"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Card de mangá -->
        <Style x:Key="MangaCardStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="CardBorder" Background="#2D2D2D" CornerRadius="6"
                                BorderBrush="#444" BorderThickness="1" Padding="0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#888"/>
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- PASTA BASE -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Folder:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="BasePathBox" Grid.Column="1" IsReadOnly="True" VerticalAlignment="Center"
                     Background="#2D2D2D" Foreground="White" BorderBrush="#555"/>
            <Button Grid.Column="2" Content="Select Folder" Click="SelectFolder_Click" Margin="8,0,0,0" Padding="10,4"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- GRID DE CARDS -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Manga List" Foreground="White" FontSize="16" Margin="0,0,0,5"/>
                <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Refresh List" Click="Refresh_Click" Padding="0,5" Margin="0,0,3,0"/>
                    <Button Grid.Column="1" x:Name="BtnRead" Click="BtnRead_Click" Padding="0,5" Margin="3,0,0,0" IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#E85D04" Opacity="{TemplateBinding Opacity}">
                                    <TextBlock Text="📖  Read Manga" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#B84500"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <ScrollViewer x:Name="MangaScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ListBox x:Name="MangaList" Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource MangaCardStyle}"
                             SelectionChanged="MangaList_SelectionChanged"
                             MouseDoubleClick="MangaList_DoubleClick"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             PreviewMouseWheel="MangaList_PreviewMouseWheel">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"
                                       Width="{Binding ViewportWidth, ElementName=MangaScrollViewer}"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="170" Margin="0">
                                    <!-- CAPA -->
                                    <Border Height="180" Background="#1a1a1a" CornerRadius="5,5,0,0">
                                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                    </Border>
                                    <!-- NOME -->
                                    <Border Background="{Binding StatusColor}" Padding="4,4,4,2">
                                        <TextBlock Text="{Binding Name}" Foreground="{Binding StatusForeground}"
                                                   FontWeight="{Binding StatusWeight}" FontSize="11"
                                                   TextWrapping="Wrap" TextAlignment="Center" MaxHeight="36"/>
                                    </Border>
                                    <!-- CHECKS -->
                                    <Border Background="#222" Padding="4,2,4,4" CornerRadius="0,0,5,5">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Chk1}" Foreground="#F448FA" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding Chk2}" Foreground="#0B47B1" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding Chk3}" Foreground="#F57927" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding Chk4}" Foreground="#F4F300" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding Chk5}" Foreground="#B1ED00" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding Chk6}" Foreground="#A855F7" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding Chk7}" Foreground="#E85D04" FontWeight="Bold" FontSize="12" Margin="2,0"/>
                                            <TextBlock Text="{Binding ChkKindle}" Foreground="White" FontSize="12" Margin="4,0,2,0"/>
                                            <TextBlock Text="{Binding ReadProgress}" Foreground="#95b634" FontSize="10" FontWeight="Bold"
                                                       VerticalAlignment="Center" Margin="1,0,2,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </DockPanel>

            <!-- DETAILS PANEL -->
            <Border Grid.Column="1" Margin="8,0" Background="#252525" CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                    <StackPanel>

                        <TextBlock x:Name="DetailMangaName" Text="Select a manga"
                                   Foreground="#666" FontSize="11" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <!-- Author -->
                        <TextBlock Text="AUTHOR" Foreground="#555" FontSize="9" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBlock x:Name="DetailAuthor" Text="—" Foreground="White"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <Separator Background="#333" Margin="0,0,0,10"/>

                        <!-- Volumes / Chapters -->
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Volumes" Foreground="#888" FontSize="11"/>
                            <TextBlock x:Name="DetailVolumes" Grid.Column="1"
                                       Text="—" Foreground="White" FontSize="11" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Chapters" Foreground="#888" FontSize="11"/>
                            <TextBlock x:Name="DetailChapters" Grid.Column="1"
                                       Text="—" Foreground="White" FontSize="11" FontWeight="Bold"/>
                        </Grid>

                        <Separator Background="#333" Margin="0,8,0,8"/>

                        <!-- Yes/No status rows -->
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Extracted" Foreground="#888" FontSize="11"/>
                            <TextBlock x:Name="DetailExtracted" Grid.Column="1" Text="—" FontSize="11" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="ComicInfo" Foreground="#888" FontSize="11"/>
                            <TextBlock x:Name="DetailComicInfo" Grid.Column="1" Text="—" FontSize="11" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Cleanup" Foreground="#888" FontSize="11"/>
                            <TextBlock x:Name="DetailCleanup" Grid.Column="1" Text="—" FontSize="11" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Mobi created" Foreground="#888" FontSize="11"/>
                            <TextBlock x:Name="DetailMobi" Grid.Column="1" Text="—" FontSize="11" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="On Kindle" Foreground="#888" FontSize="11"/>
                            <TextBlock x:Name="DetailKindle" Grid.Column="1" Text="—" FontSize="11" FontWeight="Bold"/>
                        </Grid>

                        <!-- Kindle volumes read status -->
                        <StackPanel x:Name="KindleVolumeSection" Visibility="Collapsed">
                            <Separator Background="#333" Margin="0,6,0,6"/>
                            <TextBlock Text="KINDLE VOLUMES" Foreground="#555" FontSize="9" FontWeight="Bold" Margin="0,0,0,4"/>
                            <!-- legenda -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="●" Foreground="#95b634" FontSize="9" Margin="0,0,3,0"/>
                                <TextBlock Text="Lido  " Foreground="#555" FontSize="9" Margin="0,0,8,0"/>
                                <TextBlock Text="●" Foreground="#F4A300" FontSize="9" Margin="0,0,3,0"/>
                                <TextBlock Text="Lendo  " Foreground="#555" FontSize="9" Margin="0,0,8,0"/>
                                <TextBlock Text="●" Foreground="#00A8E1" FontSize="9" Margin="0,0,3,0"/>
                                <TextBlock Text="Não lido" Foreground="#555" FontSize="9"/>
                            </StackPanel>
                            <ItemsControl x:Name="KindleVolumeList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2" Height="18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding VolumeName}" Foreground="#AAAAAA"
                                                       FontSize="10" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusIcon}"
                                                           Foreground="{Binding StatusColor}" FontSize="13"/>
                                                <TextBlock Text="{Binding PercentText}"
                                                           Foreground="{Binding StatusColor}" FontSize="9"
                                                           VerticalAlignment="Center" Margin="2,0,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- AÇÕES -->
            <Grid Grid.Column="2" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">

                <!-- Author field -->
                <Grid Height="26" Margin="0,3,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#3A3A3A" BorderBrush="#555" BorderThickness="1,1,0,1" Width="60">
                        <TextBlock Text="Author" Foreground="#AAAAAA" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11"/>
                    </Border>
                    <TextBox x:Name="AuthorBox" Grid.Column="1"
                             Background="#2D2D2D" Foreground="White" BorderBrush="#555"
                             VerticalContentAlignment="Center" Padding="5,0" FontSize="11"/>
                </Grid>

                <Button x:Name="BtnFetchAuthor" Click="FetchAuthor_Click" Height="26" Margin="0,3,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#F448FA"/>
                                <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="🔍  Fetch Author and Volumes" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnOrganize" Click="OrganizeMangaDex_Click" Height="26" Margin="0,3,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#0B47B1"/>
                                <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="📂  Organize Chapters in Volumes" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnExtract" Click="Extract_Click" Height="26" Margin="0,3,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#F57927"/>
                                <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="📦  Extract" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- GENERATE COMICINFO -->
                <Button x:Name="BtnComicInfo" Click="ComicInfo_Click" Height="26" Margin="0,3,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#F4F300"/>
                                <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="📋  Generate ComicInfo" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- CLEANUP -->
                <Button x:Name="BtnCleanup" Click="Cleanup_Click" Height="26" Margin="0,3,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#B1ED00"/>
                                <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="🧹  Cleanup Files" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- KCC: seletor de perfil + Process & Convert + Generate mobi -->
                <!-- Kindle profile selector -->
                <Grid Height="26" Margin="0,3,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="26"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Fill="#A855F7"/>
                    <ComboBox x:Name="KccProfileCombo" Grid.Column="1"
                              Background="#DDDDDD" BorderThickness="0"
                              VerticalContentAlignment="Center" Padding="5,0" FontSize="11"/>
                </Grid>

                <!-- Process & Convert -->
                <Button x:Name="BtnResize" Click="KCC_Click" Height="26" Margin="0,3,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#A855F7"/>
                                <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                    <TextBlock Text="⚙  Process &amp; Convert" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Generate mobi -->
                <Button x:Name="BtnOpenKCC" Click="OpenKCC_Click" Height="26" Margin="0,3,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#A855F7"/>
                                <Border x:Name="Bd" Grid.Column="1" Background="#C0392B">
                                    <TextBlock Text="🔄 Generate mobi" Foreground="White" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#922B21"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- VOLUME SELECTOR -->
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="Select which volumes you want to send to Kindle"
                               Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="ChkSendAll" Content="All" IsChecked="True"
                                  Foreground="White" VerticalAlignment="Center"
                                  Checked="ChkSendAll_Checked" Unchecked="ChkSendAll_Unchecked"
                                  Margin="0,0,12,0"/>
                        <CheckBox x:Name="ChkSendRange" Content="Range"
                                  Foreground="White" VerticalAlignment="Center"
                                  Checked="ChkSendRange_Checked" Unchecked="ChkSendRange_Unchecked"
                                  Margin="0,0,8,0"/>
                        <TextBox x:Name="VolumeRangeBox"
                                 Width="120" IsEnabled="False"
                                 Background="#2D2D2D" Foreground="White" BorderBrush="#555"
                                 VerticalContentAlignment="Center" Padding="6,2"
                                 Text="" Tag="1,2,3 or 1-6"/>
                    </StackPanel>
                </StackPanel>

                <!-- SEND TO KINDLE -->
                <Grid Height="32" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnSendToKindle" Grid.Column="0" Click="SendToKindle_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="#00A8E1"/>
                                    <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                        <TextBlock Text="📱  Send to Kindle" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="BtnRemoveFromKindle" Grid.Column="1" Click="RemoveFromKindle_Click" Margin="4,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#DDDDDD" BorderBrush="#AAAAAA" BorderThickness="1,0,0,0">
                                    <TextBlock Text="🗑 Remove" Foreground="#CC3333" FontSize="11"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- EMAIL TO KINDLE APP (expansível) -->
                <Expander x:Name="EmailExpander" Margin="0,10,0,0" IsExpanded="False">
                    <Expander.Header>
                        <TextBlock Text="📧  Send to Kindle by Email" Foreground="#CCCCCC"
                                   FontWeight="Bold" FontSize="12"/>
                    </Expander.Header>
                    <Expander.Style>
                        <Style TargetType="Expander">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="#444"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Expander">
                                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4" Background="#1a1a1a">
                                            <StackPanel>
                                                <!-- Header clicável -->
                                                <ToggleButton x:Name="HeaderToggle"
                                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                              Background="Transparent" BorderThickness="0"
                                                              Padding="8,6" HorizontalContentAlignment="Left"
                                                              Cursor="Hand">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                                                                    <TextBlock x:Name="Arrow" Grid.Column="1"
                                                                               Text="▶" Foreground="#888" FontSize="10"
                                                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                                </Grid>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                    <ContentPresenter ContentSource="Header"/>
                                                </ToggleButton>
                                                <!-- Conteúdo expansível -->
                                                <ContentPresenter x:Name="Content" Margin="8,0,8,8"
                                                                  Visibility="Collapsed"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsExpanded" Value="True">
                                                <Setter TargetName="Content" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Expander.Style>

                    <StackPanel>
                        <!-- Sender email -->
                        <Grid Height="26" Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Your email" Foreground="#AAAAAA"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBox x:Name="SenderEmailBox" Grid.Column="1"
                                     Background="#2D2D2D" Foreground="White" BorderBrush="#555"
                                     VerticalContentAlignment="Center" Padding="4,0" FontSize="11"
                                     TextChanged="EmailFields_Changed"/>
                        </Grid>

                        <!-- App password -->
                        <Grid Height="26" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="App password" Foreground="#AAAAAA"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <PasswordBox x:Name="AppPasswordBox" Grid.Column="1"
                                         Background="#2D2D2D" Foreground="White" BorderBrush="#555"
                                         Padding="4,0" FontSize="11"
                                         PasswordChanged="EmailFields_Changed"/>
                        </Grid>

                        <!-- Kindle email -->
                        <Grid Height="26" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Kindle email" Foreground="#AAAAAA"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBox x:Name="KindleEmailBox" Grid.Column="1"
                                     Background="#2D2D2D" Foreground="White" BorderBrush="#555"
                                     VerticalContentAlignment="Center" Padding="4,0" FontSize="11"
                                     TextChanged="EmailFields_Changed"/>
                        </Grid>

                        <!-- Hint -->
                        <TextBlock Foreground="#666666" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,6">
                            <Run Text="⚠ Use an App Password, not your account password."/>
                            <LineBreak/>
                            <Run Text="Gmail → myaccount.google.com/apppasswords"/>
                            <LineBreak/>
                            <Run Text="iCloud → appleid.apple.com › Sign-In and Security"/>
                            <LineBreak/>
                            <Run Text="Add your sender email to Amazon's approved list:"/>
                            <LineBreak/>
                            <Run Text="amazon.com › Account › Manage Your Content and Devices"/>
                        </TextBlock>

                        <!-- Send button -->
                        <Button x:Name="BtnSendByEmail" Click="SendByEmail_Click" Height="30" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Fill="#1A73E8"/>
                                        <Border x:Name="Bd" Grid.Column="1" Background="#DDDDDD">
                                            <TextBlock Text="📧  Send to Kindle by Email" FontSize="11"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#BBBBBB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Expander>

                <!-- PROGRESSO -->
                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="ProgressBar" Grid.Column="0" Height="18" Minimum="0" Maximum="100"/>
                    <Button x:Name="BtnCancel" Grid.Column="1" Click="Cancel_Click"
                            Margin="6,0,0,0" Height="18" IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#CC3333" CornerRadius="3">
                                    <TextBlock Text="⏹ Cancel" Foreground="White" FontSize="10"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Background" Value="#555555"/>
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#AA2222"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <TextBlock x:Name="ProgressText" Foreground="#AAAAAA" FontSize="12" Margin="0,2,0,0"/>

                </StackPanel>

                <!-- LOG -->
                <TextBox x:Name="LogBox" Grid.Row="1" Margin="0,10,0,0"
                         IsReadOnly="True" TextWrapping="Wrap"
                         Background="#2D2D2D" Foreground="#CCCCCC" BorderBrush="#555"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
