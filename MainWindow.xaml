<Window x:Class="MangaManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manga Manager" Height="580" Width="900"
        Background="#1E1E1E">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- PASTA BASE -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Folder:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="BasePathBox" Width="620" IsReadOnly="True" VerticalAlignment="Center"
                     Background="#2D2D2D" Foreground="White" BorderBrush="#555"/>
            <Button Content="Select Folder" Click="SelectFolder_Click"
                    Margin="8,0,0,0" Padding="10,4"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- LISTA -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Manga List" Foreground="White" FontSize="16" Margin="0,0,0,5"/>
                <ListBox x:Name="MangaList" Height="420"/>
                <Button Content="Refresh List" Click="Refresh_Click" Margin="0,8,0,0" Padding="0,5"/>
            </StackPanel>

            <!-- AÇÕES -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0">

                <TextBlock Text="Author" Foreground="White"/>
                <DockPanel Margin="0,5,0,10">
                    <Button Content="🔍 Fetch Author and Volumes (AniList)" DockPanel.Dock="Right"
                            Click="FetchAuthor_Click" Padding="10,0" Margin="6,0,0,0"/>
                    <TextBox x:Name="AuthorBox"/>
                </DockPanel>

                <Button Content="📂 Organize Chapters in Volumes" Click="OrganizeMangaDex_Click" Height="32" Margin="0,4,0,0" Background="#2A5298" Foreground="White"/>
                <Button Content="📦 Extract CBZ"                  Click="Extract_Click"          Height="32" Margin="0,4,0,0"/>
                <Button Content="📋 Generate ComicInfo"           Click="ComicInfo_Click"        Height="32" Margin="0,4,0,0"/>
                <Button Content="🧹 Cleanup CBZ Files"            Click="Cleanup_Click"          Height="32" Margin="0,4,0,0" Background="#5C3317" Foreground="White"/>

                <!-- PROGRESSO -->
                <ProgressBar x:Name="ProgressBar" Height="18" Margin="0,14,0,4" Minimum="0" Maximum="100"/>
                <TextBlock x:Name="ProgressText" Foreground="#AAAAAA" FontSize="12"/>

                <!-- LOG -->
                <TextBox x:Name="LogBox" Height="180" Margin="0,10,0,0"
                         IsReadOnly="True" TextWrapping="Wrap"
                         Background="#2D2D2D" Foreground="#CCCCCC" BorderBrush="#555"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
